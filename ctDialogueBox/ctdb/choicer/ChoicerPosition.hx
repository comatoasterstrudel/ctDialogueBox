package ctDialogueBox.ctdb.choicer;

/**
 * an enum to dictate where the texts on the choicer will appear
 */
enum ChoicerPosition
{
    /**
     * the choicer texts will appear on the left of the dialogue box
     */
    Left;
    
    /**
     * the choicer texts will appear in the center of the dialogue box
     */
    Center;
    
    /**
     * the choicer texts will appear on the right of the dialogue box
     */
    Right;
}